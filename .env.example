# Copy to .env.local for local dev, and set these in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=contact@gasperohlab.com

# Sender. The domain MUST be verified in Resend (Domains → Add domain,
# then add the DNS records). Example: "GASPEROHLAB <noreply@gasperohlab.com>"
CONTACT_FROM_EMAIL=GASPEROHLAB <noreply@gasperohlab.com>

# Google Search Console verification token (optional).
GOOGLE_SITE_VERIFICATION=
